# Copy this file to .env and paste your tokens in. Do not commit .env.
# The script auto-loads .env on every run. A real exported env var overrides it.

# GitHub personal access token. Lifts the search rate limit and lets GitHub
# ingest go deep. Needs no scopes for public repo search.
GITHUB_TOKEN=

# Product Hunt developer token. Turns the Product Hunt connector on.
PRODUCT_HUNT_TOKEN=

# Optional. Anthropic API key to use the model classifier instead of the
# keyword heuristic.
ANTHROPIC_API_KEY=
